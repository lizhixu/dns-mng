# JWT Secret Key (IMPORTANT: Change this in production!)
JWT_SECRET=dns-mng-secret-key-change-in-production

# Database type: "sqlite" (default, local file) or "libsql" (Turso / remote libSQL)
# DB_TYPE=sqlite

# --- SQLite (used when DB_TYPE=sqlite) ---
# Database path (default: /data/dns-mng.db in container)
# DB_PATH=/data/dns-mng.db

# --- libSQL / Turso (used when DB_TYPE=libsql) ---
# Requires linux/darwin (amd64/arm64) with CGO enabled (the Windows host build
# falls back to sqlite; use the Docker image to connect to Turso).
#
# Turso remote example:
# DB_URL=libsql://your-db.turso.io
# DB_AUTH_TOKEN=your-turso-auth-token
#
# libSQL local file example (no token needed):
# DB_URL=file:/data/dns-mng.db

# Server port (default: 8080)
# SERVER_PORT=8080
