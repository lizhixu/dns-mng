    "/internal/migration/domain": {
      "post": {
        "operationId": "internalMigration.migrateDomain",
        "tags": [
          "InternalMigration"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "subdomain": {
                    "type": "string",
                    "description": "メールアドレス必須",
                    "pattern": "^[a-z0-9]([a-z0-9\\-]{1,61})[a-z0-9]$",
                    "minLength": 3,
                    "maxLength": 63
                  }
                },
                "required": [
                  "email",
                  "subdomain"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "message": {
                      "type": "string",
                      "enum": [
                        "Domain migrated successfully"
                      ]
                    },
                    "subdomain": {
                      "type": "string"
                    },
                    "email": {
                      "type": "string"
                    },
                    "action": {
                      "type": "string",
                      "enum": [
                        "MIGRATION_LINKED"
                      ]
                    }
                  },
